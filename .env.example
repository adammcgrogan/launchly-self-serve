# Copy to .env for local development. In production these are set as
# platform env vars (e.g. in the Railway dashboard) — see internal/config.

ADDR=:8080
DOMAIN=localhost:8080

# Supabase Postgres connection string (Settings → Database → Connection string)
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# Supabase Auth (Settings → API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@launchly.ltd

# Superadmin (shared password, separate from customer accounts)
SUPERADMIN_PASSWORD=changeme

# HMAC key for CSRF/flash cookies — any long random string
COOKIE_SIGNING_KEY=change-this-to-a-long-random-string

# Optional: Umami analytics script URL, embedded on published sites
UMAMI_SCRIPT_URL=
